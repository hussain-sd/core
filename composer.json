{
  "name": "smart-till/core",
  "description": "SMART TiLL core Filament modules",
  "type": "library",
  "license": "MIT",
  "require": {
    "php": "^8.2",
    "filament/filament": "^5.0",
    "laravel/framework": "^12.0",
    "laravel/sanctum": "^4.0",
    "league/iso3166": "^4.3",
    "livewire/livewire": "^4.0",
    "pragmarx/countries": "^1.0"
  },
  "autoload": {
    "psr-4": {
      "SmartTill\\Core\\": "src/"
    }
  },
  "extra": {
    "laravel": {
      "providers": [
        "SmartTill\\Core\\Providers\\CoreServiceProvider"
      ]
    }
  },
  "minimum-stability": "stable",
  "prefer-stable": true
}
