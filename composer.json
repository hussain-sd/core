{
  "name": "smart-till/core",
  "description": "SMART TiLL core Filament modules",
  "type": "library",
  "license": "MIT",
  "require": {
    "php": "^8.2",
    "filament/filament": "^5.0",
    "laravel/framework": "^13.0",
    "laravel/sanctum": "^4.0",
    "league/iso3166": "^4.3",
    "livewire/livewire": "^4.0",
    "pragmarx/countries": "^1.0",
    "simplesoftwareio/simple-qrcode": "^4.2"
  },
  "autoload": {
    "psr-4": {
      "SmartTill\\Core\\": "src/"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "SmartTill\\Core\\Tests\\": "tests/"
    }
  },
  "scripts": {
    "test": "@php vendor/bin/pest"
  },
  "extra": {
    "laravel": {
      "providers": [
        "SmartTill\\Core\\Providers\\CoreServiceProvider"
      ]
    }
  },
  "minimum-stability": "stable",
  "prefer-stable": true,
  "require-dev": {
    "pestphp/pest": "^4",
    "pestphp/pest-plugin-laravel": "^4",
    "orchestra/testbench": "^11.0"
  },
  "config": {
    "allow-plugins": {
      "pestphp/pest-plugin": true
    }
  }
}
